<button
  id="theme-toggle"
  class="cursor-pointer p-1 text-ink-light hover:text-accent transition-colors"
  aria-label="Cambiar tema"
>
  <svg
    class="block h-4 w-4 dark:hidden"
    viewBox="0 0 16 16"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
  >
    <path d="M13 10.5A5.5 5.5 0 0 1 5.5 3 5 5 0 1 0 13 10.5Z" />
  </svg>
  <svg
    class="hidden h-4 w-4 dark:block"
    viewBox="0 0 16 16"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
  >
    <circle cx="8" cy="8" r="3.5" />
    <path d="M8 1v1M8 14v1M1 8h1M14 8h1M3.05 3.05l.7.7M12.25 12.25l.7.7M3.05 12.95l.7-.7M12.25 3.75l.7-.7" />
  </svg>
</button>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
