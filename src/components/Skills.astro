---
const skillGroups = [
	{
		category: 'Frontend',
		skills: ['React', 'Next.js', 'TypeScript', 'Vite'],
	},
	{
		category: 'Backend',
		skills: ['Node.js', 'NestJS', 'Express.js', 'Python', 'C#', '.NET'],
	},
	{
		category: 'Bases de datos',
		skills: ['PostgreSQL', 'MySQL', 'MariaDB', 'SQLite', 'Prisma ORM'],
	},
	{
		category: 'Herramientas',
		skills: ['Git', 'Linux', 'Electron', 'Windows'],
	},
];
---

<section id="skills" class="mx-auto max-w-2xl px-8 py-24">
	<h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
		Skills
	</h2>
	<div class="mt-12 grid gap-10 sm:grid-cols-2">
		{
			skillGroups.map((group) => (
				<div>
					<h3 class="font-mono text-xs font-medium tracking-widest text-ink-muted uppercase">{group.category}</h3>
					<div class="mt-3 flex flex-wrap gap-2">
						{group.skills.map((skill) => (
							<span class="rounded-sm border border-ink/10 px-3 py-1 font-mono text-sm text-ink">{skill}</span>
						))}
					</div>
				</div>
			))
		}
	</div>
</section>
